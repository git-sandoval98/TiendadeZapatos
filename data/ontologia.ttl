:fechaVenta a owl:DatatypeProperty ; rdfs:domain :Venta ; rdfs:range xsd:dateTime .
:total a owl:DatatypeProperty ; rdfs:domain :Venta ; rdfs:range xsd:decimal .
:cantidadVendida a owl:DatatypeProperty ; rdfs:domain :DetalleVenta ; rdfs:range xsd:integer .
:precioUnitario a owl:DatatypeProperty ; rdfs:domain :DetalleVenta ; rdfs:range xsd:decimal .
:nombreTemporada a owl:DatatypeProperty ; rdfs:domain :Temporada ; rdfs:range xsd:string .
:anio a owl:DatatypeProperty ; rdfs:domain :Temporada ; rdfs:range xsd:integer .

